.card {
  border: 1px solid #d7d7d7;
  border-radius: 12px;
  padding: 24px;
}

.header,
li {
  align-items: center;
  display: flex;
  gap: 16px;
  justify-content: space-between;
}

.users {
  display: grid;
  gap: 12px;
  list-style: none;
  padding: 0;
}

li {
  border: 1px solid #eeeeee;
  border-radius: 10px;
  padding: 12px;
}

span {
  color: #5f6368;
  display: block;
  font-size: 0.9rem;
  margin-top: 4px;
}

button {
  border: 0;
  border-radius: 8px;
  cursor: pointer;
  font: inherit;
  padding: 8px 12px;
}

.secondary {
  background: transparent;
  border: 1px solid #bdbdbd;
}
